{
  "name": "tool-demo-script-skill",
  "version": "0.1.0",
  "description": "Generate concise tool-demo scripts from repo metadata, CLI examples, and safety notes.",
  "type": "commonjs",
  "bin": {
    "tool-demo-script": "bin/tool-demo-script.js"
  },
  "scripts": {
    "test": "node --test",
    "check": "node --check src/index.js && node --check bin/tool-demo-script.js",
    "build": "node scripts/build.js",
    "smoke": "node bin/tool-demo-script.js fixtures/repo-card.json",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm run check && npm run build && npm test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "agent-skill",
    "dry-run",
    "cli"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/tool-demo-script-skill.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/tool-demo-script-skill/issues"
  },
  "homepage": "https://github.com/rogerchappel/tool-demo-script-skill#readme",
  "files": [
    "bin",
    "src",
    "docs",
    "fixtures",
    "SKILL.md",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md"
  ]
}
